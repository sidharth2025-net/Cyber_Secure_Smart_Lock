#include <Arduino.h>
#include <Wire.h>
#include <Adafruit_GFX.h>
#include <Adafruit_SSD1306.h>
#include <Keypad.h>
#include <RTClib.h>

#define SCREEN_WIDTH 128 
#define SCREEN_HEIGHT 64
#define OLED_RESET -1
Adafruit_SSD1306 display(SCREEN_WIDTH, SCREEN_HEIGHT, &Wire, OLED_RESET);
RTC_DS3231 rtc;

const byte ROWS = 4;
const byte COLS = 4;

// Define the keypad key map
char keys[ROWS][COLS] = {
  {'1', '2', '3', 'A'},
  {'4', '5', '6', 'B'},
  {'7', '8', '9', 'C'},
  {'*', '0', '#', 'D'}
};

// Define the Arduino pins connected to the keypad rows and columns
byte rowPins[ROWS] = {9, 8, 7, 6}; // Connect to the row pins of the keypad
byte colPins[COLS] = {5, 4, 3, 2}; // Connect to the column pins of the keypad

// Create the Keypad object
Keypad customKeypad = Keypad(makeKeymap(keys), rowPins, colPins, ROWS, COLS);

// Define the correct password
String correctPassword = "2025"; // Change this to your desired password

// Define the maximum password length
const int MAX_PASSWORD_LENGTH = 10;
char enteredPassword[MAX_PASSWORD_LENGTH];
byte passwordIndex = 0;

// Define LED and Buzzer pins
const int ledPin = 10;
const int buzzerPin = 13;

bool isBuzzerActive = false; // Flag to control buzzer state

void setup() {
  Serial.begin(9600);
  pinMode(ledPin, OUTPUT);
  pinMode(buzzerPin, OUTPUT);
  digitalWrite(ledPin, LOW); // Ensure LED is off initially
  digitalWrite(buzzerPin, LOW); // Ensure buzzer is off initially

  if (!rtc.begin()) {
    Serial.println("Couldn't find RTC");
    Serial.flush();
    while (1) delay(10);
  }

  // SSD1306 OLED display initialization
  if (!display.begin(SSD1306_SWITCHCAPVCC, 0x3C)) { // Address 0x3C for 128x64
    Serial.println(F("SSD1306 allocation failed"));
    for (;;); // Don't proceed, loop forever
  }
  display.display();
  delay(1000);
  display.clearDisplay();
  display.setTextSize(1);
  display.setTextColor(SSD1306_WHITE);
  display.setCursor(0, 0);
  display.println("Enter Password:");
  display.display();

  // Initial buzzer ring for system start (you can remove this if not desired)
  for (int i = 0; i < 3; i++) {
    tone(buzzerPin, 1000); // Play a tone
    delay(100);
    noTone(buzzerPin);    // Stop the tone
    delay(100);
  }
}

void loop() {
  char key = customKeypad.getKey();

  if (key) {
    Serial.println(key);

    if (key == '#') { // Use '#' as the enter key
      checkPassword();
      clearEnteredPassword();
      display.clearDisplay();
      display.setCursor(0, 0);
      display.println("Enter Password:");
      display.display();
    } else if (key == '*') { // Use '*' as the backspace/clear key (optional)
      if (passwordIndex > 0) {
        passwordIndex--;
        enteredPassword[passwordIndex] = '\0'; // Remove last character
        display.clearDisplay();
        display.setCursor(0, 0);
        display.println("Enter Password:");
        display.setCursor(0, 10);
        for (int i = 0; i < passwordIndex; i++) {
          display.print("*");
        }
        display.display();
      }
    } else if (passwordIndex < MAX_PASSWORD_LENGTH - 1) {
      enteredPassword[passwordIndex++] = key;
      enteredPassword[passwordIndex] = '\0'; // Null-terminate the string
      display.setCursor(0, 10);
      for (int i = 0; i < passwordIndex; i++) {
        display.print("*");
      }
      display.display();
    }
  }
}

void checkPassword() {
  if (String(enteredPassword) == correctPassword) {
    display.clearDisplay();
    display.setTextSize(2);
    display.setCursor(0, 20);
    display.println("Access Granted!");
    display.display();
    digitalWrite(ledPin, HIGH); // Turn on LED
    delay(2000);
    digitalWrite(ledPin, LOW);  // Turn off LED
    display.clearDisplay();
    display.setTextSize(1);
    display.setCursor(0, 0);
    display.println("Enter Password:");
    display.display();
    isBuzzerActive = false; // Ensure buzzer is off after correct password
  } else {
    display.clearDisplay();
    display.setTextSize(1);
    display.setCursor(0, 10);
    display.println("CYBER DEPARTMENT");
    display.setCursor(0, 20);
    display.println("MONITORING");
    display.setCursor(0, 40);
    display.println("NOTIFICATION SENDS TO HOUSE OWNER");
    display.display();

    // Activate buzzer sound for incorrect password
    for (int i = 0; i < 2; i++) {
      tone(buzzerPin, 500); // Play a tone
      delay(300);
      noTone(buzzerPin);    // Stop the tone
      delay(300);
    }
    isBuzzerActive = true; // Set flag that buzzer was active

    delay(5000); // Display the message for 5 seconds

    display.clearDisplay();
    display.setTextSize(1);
    display.setCursor(0, 0);
    display.println("Enter Password:");
    display.display();
  }
}

void clearEnteredPassword() {
  for (int i = 0; i < MAX_PASSWORD_LENGTH; i++) {
    enteredPassword[i] = '\0';
  }
  passwordIndex = 0;
}
